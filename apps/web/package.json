{
  "name": "@mindfull/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "android:apk": "pnpm android:sync && ./android/gradlew -p android assembleDebug",
    "android:open": "cap open android",
    "android:release": "pnpm android:sync && ./android/gradlew -p android assembleRelease",
    "android:run": "pnpm android:sync && cap run android",
    "android:sync": "pnpm --filter @mindfull/domain build && pnpm build:native && cap sync android",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:native": "tsc -p tsconfig.json --noEmit && vite build --mode native",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@mindfull/domain": "workspace:*",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "jotai": "^2.20.2",
    "react": "^19.2.7",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.7",
    "react-is": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^8.2.0",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
