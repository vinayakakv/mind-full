# Prefer the immutable sha-<commit> tag shown on the GHCR package page.
MINDFULL_VERSION=latest

# Replace this before starting Mindfull. Devices use it only during pairing.
MINDFULL_PAIRING_CODE=replace-with-a-long-random-value

# Keep the container private to this host and expose it through Tailscale Serve.
MINDFULL_BIND_ADDRESS=127.0.0.1
MINDFULL_PORT=3001
