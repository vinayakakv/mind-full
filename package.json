{
  "name": "mindfull",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "patchedDependencies": {
      "@capacitor/android@8.4.2": "patches/@capacitor__android@8.4.2.patch"
    }
  },
  "scripts": {
    "android:apk": "pnpm --filter @mindfull/web android:apk",
    "android:open": "pnpm --filter @mindfull/web android:open",
    "android:release": "pnpm --filter @mindfull/web android:release",
    "android:run": "pnpm --filter @mindfull/web android:run",
    "android:sync": "pnpm --filter @mindfull/web android:sync",
    "build": "pnpm --filter @mindfull/domain build && pnpm --filter @mindfull/web build && pnpm --filter @mindfull/server build",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "dev": "pnpm --filter @mindfull/domain build && pnpm --parallel --filter @mindfull/web --filter @mindfull/server dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "import:stoic": "pnpm --filter @mindfull/domain build && pnpm --filter @mindfull/server import:stoic",
    "lint": "biome lint .",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @mindfull/domain typecheck && pnpm --filter @mindfull/web typecheck && pnpm --filter @mindfull/server typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "1.61.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
